{
        "$schema": "/etc/xdg/swaync/configSchema.json",
        "positionX": "right",
        "positionY": "top",
        "cssPriority": "user",
        "layer-shell-osd": true,
        "control-center-positive-action-icon": true,
        "control-center-width": 500,
        "control-center-height": 1160,
        "control-center-margin-top": 6,
        "control-center-margin-bottom": 6,
        "control-center-margin-right": 6,
        "control-center-margin-left": 6,
        "notification-window-width": 400,
        "notification-icon-size": 28,
        "notification-body-image-height": 160,
        "notification-body-image-width": 200,
        "timeout": 2,
        "timeout-low": 2,
        "timeout-critical": 0,
        "fit-to-screen": false,
        "keyboard-shortcuts": true,
        "image-visibility": "when-available",
        "transition-time": 200,
        "hide-on-clear": true,
        "hide-on-action": true,
        "script-fail-notify": true,
        "notification-visibility": {
                "browser-and-music": {
                        "state": "enabled",
                        "app-name": "(?i)(firefox|chromium|chrome|brave|zen|spotify)"
                },
                "network-alerts": {
                        "state": "enabled",
                        "app-name": "(?i)(networkmanager|network|nm-applet)"
                },
                "osd-controls": {
                        "state": "enabled",
                        "app-name": "(?i)(volume|brightness|microphone|battery)"
                }
        },
        "widgets": [
                "label",
                "buttons-grid",
                "mpris",
                "title",
                "dnd",
                "volume",
                "backlight",
                "notifications"
        ],
        "widget-config": {
                "title": {
                        "text": "Notifications",
                        "clear-all-button": true,
                        "button-text": "󰎟"
                },
                "dnd": {
                        "text": "Do Not Disturb"
                },
                "label": {
                        "max-lines": 1,
                        "text": " "
                },
                "mpris": {
                        "image-size": 96,
                        "image-radius": 12
                },
                "volume": {
                        "label": "󰕾",
                        "show-per-app": true
                },
                "backlight": {
                        "label": "󰃠",
                        "device": "intel_backlight"
                },
                "buttons-grid": {
                        "actions": [
                                { "label": "", "command": "pamixer -t" },
                                { "label": "", "command": "pamixer --default-source -t" },
                                { "label": "", "command": "nmrs" },
                                { "label": "󰂯", "command": "blueman-manager" },
                                { "label": "󰏘", "command": "nwg-look" },
                                { "label": "󰌌", "command": "wlogout -b 3 -c 10 -r 10" }
                        ]
                }
        }
}
