{
    "layer": "top",
    "position": "top",
    "margin-bottom": 0,
    "margin-top": 5,
    "spacing" : 0,
    "modules-left": [
        "ext/workspaces",
        // "hyprland/workspaces",
        "hyprland/window",
    ],

    "modules-center": ["clock"],

    "modules-right": [
        "bluetooth",
        "network",
        "pulseaudio", 
        "backlight",
        "battery",
        "custom/swaync"
    ],
    "tray": {
        "icon-size": 18,
        "spacing": 5
    },
    "custom/swaync": {
        "tooltip": true,     
        "format": "{icon}", // Changed from "{icon} {text}" to just show the icon cleanly
        "format-icons": {
            "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "none": "ΎΓλ",
            "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "dnd-none": "ΎΘ╖",
            "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "inhibited-none": "ΎΓλ",
            "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "dnd-inhibited-none": "ΎΘ╖"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "clock": {
        "timezone": "Asia/Kolkata",

        "format": "≤░ξΦ {:%H:%M ≤░Δχ %B %d, %Y}",
        "format-alt": "≤░ξΦ {:%H:%M}",
        "tooltip-format": "<big>{calendar}</big>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#d3c6aa'><b>{}</b></span>",
                "days": "<span color='#e67e80'>{}</span>",
                "weeks": "<span color='#a7c080'><b>W{}</b></span>",
                "weekdays": "<span color='#7fbbb3'><b>{}</b></span>",
                "today": "<span color='#dbbc7f'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "hyprland/window": {
        "format": "<span color='#e0def4'> ΎΤΙ {title}</span>",
        "max-length":20,
        "rewrite": {
            "(.*) - Mozilla Firefox": "ΏθΝΟ $1",
            "(.*) - zsh": "> [$1]"
        }
    },
    "ext/workspaces": {
        "format": "{name}",
        // "format": "{name}: {icon}",
        "format-icons": {
            "active": "ΎΗΤ",
            "default": "ΎΕΣ"
        },
        "on-click": "activate",
        "all-outputs": true,
        "sort-by-number": true
    },

   "hyprland/workspaces": {
        "format": "{name}",
        "format-icons": {
            "active": "ΎΗΤ",
            "default": "ΎΕΣ"
        },
        // "on-click": "activate",
        "all-outputs": true,
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 5 
        }
    },

    "bluetooth": {
        "format": "≤░Γ▓",
        "format-on": "{icon}",
        "format-off": "{icon}", 
        "format-connected":"{icon}",
        "format-icons":{
            "on":"≤░Γψ",
            "off": "≤░Γ▓",
            "connected": "≤░Γ▒",
        },
        "on-click": "blueman-manager",
        "tooltip-format-connected":"{device_enumerate}"
    },

    "custom/music": {
        "format": "ΎΑΒ  {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ artist }} - {{ title }}'",
        "on-click": "playerctl play-pause",
        "max-length": 50
    },

    "network": {
        "format-wifi": "≤░νλ",
        "format-ethernet": "≤░ΙΑ ",
        "format-disconnected": "≤░νι ",
        "interval": 5,
        "tooltip-format": "{essid} ({signalStrength}%)",
        "on-click": "exec nmrs"
        // "on-click": "~/.local/bin/rofi-wifi-menu"
    },

    "cpu": {
        "interval": 1,
        "format": "ΎΜδ  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
        "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"],
        "on-click": "ghostty -e htop"
    },

    "memory": {
        "interval": 30,
        "format": "Ό┐Ζ  {used:0.1f}G/{total:0.1f}G",
        "tooltip-format": "Memory"
    },

    "custom/uptime": {
        "format": "{}",
        "format-icon": ["ΎΒλ"], 
        "tooltip": false,
        "interval": 1600,
        "exec": "$HOME/.config/waybar/scripts/uptime.sh"
    },

    "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": ["ΌΟΞ","≤░Δε", "≤░Δδ", "≤░Δη","≤░Δζ","≤░Δθ","≤░Δι"],
        "tooltip": false
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "ΎΣο",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ "]
        },
        "on-click": "pavucontrol"
    },

    "battery": {
        "interval":2,
        "states": {
            "good": 95,
            "warning": 15,
            "critical": 5
        },
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "ΎΘο {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-alt": "{icon} {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },

    "custom/lock": {
        "tooltip": false,
        "on-click": "sh -c '(sleep 0s; hyprlock)' & disown",
        "format" : "ΎΑμ"
    },

    "custom/pomodoro": {
        "format": "{}",
        "return-type": "json",
        "exec": "waybar-module-pomodoro --no-work-icons",
        "on-click": "waybar-module-pomodoro toggle",
        "on-click-right": "waybar-module-pomodoro reset",
    },

}

