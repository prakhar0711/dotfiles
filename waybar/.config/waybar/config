{
        "layer": "top",
        "position": "top",
        "margin-bottom": 5,
        "margin-top": 5,
        "spacing" : 0,
        "modules-left": [
                "ext/workspaces",
                // "hyprland/workspaces",
                "hyprland/window",
        ],

        "modules-center": ["clock"],

        "modules-right": [
                "bluetooth",
                "network",
                "pulseaudio", 
                "backlight",
                "battery",
        ],
        "tray": {
