

Xft.dpi: 120

Xft.antialias:                  1
Xft.autohint:                   1
Xft.hinting:                    1
Xft.hintstyle:                  hintslight
Xft.lcdfilter:                  lcdlight
Xft.rgba:                       rgb

! --- Xterm Color Scheme ---
! Use a modern font (requires xft)
xterm*faceName: Ubuntu Mono:size=18
xterm*renderFont: true

! Remove the internal border
xterm*internalBorder: 10

! Enable 256 colors
xterm*termName: xterm-256color
xterm*background: #000000
xterm*foreground: #a9b1d6
xterm*cursorColor: #f7768e

! black
xterm*color0: #15161e
xterm*color8: #414868
! red
xterm*color1: #f7768e
xterm*color9: #f7768e
! green
xterm*color2: #9ece6a
xterm*color10: #9ece6a
! yellow
xterm*color3: #e0af68 xterm*color11: #e0af68 ! blue
xterm*color4: #7aa2f7
xterm*color12: #7aa2f7
! magenta
xterm*color5: #bb9af7
xterm*color13: #bb9af7
! cyan
xterm*color6: #7dcfff
xterm*color14: #7dcfff
! white
xterm*color7: #a9b1d6
xterm*color15: #c0caf5

*background:   #000000
*foreground:   #cdd6f4
*color0:        #1e1e2e
*color1:        #f38ba8
*color2:        #a6e3a1
*color3:        #f9e2af
*color4:        #89b4fa
*color5:        #f5c2e7
*color6:        #94e2d5
*color7:        #bac2de
*color8:        #585b70
*color9:        #f38ba8
*color10:       #a6e3a1
*color11:       #f9e2af
*color12:       #89b4fa
*color13:       #f5c2e7
*color14:       #94e2d5
*color15:       #a6adc8
*color16:       #faa000
